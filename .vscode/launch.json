{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug with tsx",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "tsx",
        "src/index.ts"
      ],
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/node_modules/**/*.js"
      ],
      "console": "integratedTerminal"
    }
  ]
}